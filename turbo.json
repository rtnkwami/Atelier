{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": { 
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "tsconfig.json",
        "test/**/*.ts",
        "eslint.config.mjs"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "test/**/*.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ]
    }
  },
  "cacheDir": ".turbo/cache"
}