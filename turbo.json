{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": { "dependsOn": ["^build"] },
    "dev": {
      "persistent": true,
      "cache": false
    }
  },
  "cacheDir": ".turbo/cache"
}